#!/usr/bin/env python3

"""Ensure that GitLab's openssh server closes idle connections."""

import re
import sys
import yaml

def do_patch(obj):
    if obj["kind"] != "ConfigMap":
        return obj

    if "sshd" not in obj["metadata"]["name"]:
        return obj

    if "sshd_config" not in obj["data"]:
        return obj

    sshd_config = obj["data"]["sshd_config"]

    sshd_config = patch_one_line(
        sshd_config,
        "ChannelTimeout",
        "ChannelTimeout session=5m")

    sshd_config = patch_one_line(
        sshd_config,
        "UnusedConnectionTimeout",
        "UnusedConnectionTimeout 5m")

    obj["data"]["sshd_config"] = sshd_config 

    return obj


def patch_one_line (config_multiline, keyword, replacement):
    """Replace any occurrence of `keyword` on a line with `replacement`.

    This is idempotent and works regardless of whether `keyword` is
    present, absent, or commented out.
    """
    if not config_multiline.endswith("\n"):
        config_multiline = "%s\n" % config_multiline
    keep_lines = [l for l in config_multiline.split("\n")
                  if keyword not in l][:-1]
    return "".join(
        "%s\n" % l for l in keep_lines + [replacement])


for obj in yaml.load_all(sys.stdin, yaml.SafeLoader):
    if obj is None:
        continue
    obj = do_patch(obj)
    sys.stdout.write("---\n" + yaml.dump(obj))
